{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "arrowParentheses": "asNeeded",
      "quoteProperties": "preserve"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noDoubleEquals": "off",
        "noAssignInExpressions": "off",
        "useIterableCallbackReturn": "off"
      },
      "complexity": {
        "noForEach": "off"
      },
      "style": {
        "noParameterAssign": "off",
        "useNodejsImportProtocol": "off",
        "useConst": "warn"
      },
      "performance": {
        "noAccumulatingSpread": "warn"
      }
    }
  },
  "files": {
    "includes": [
      "packages/import-cost/src/**",
      "packages/vscode-import-cost/src/**",
      "packages/vscode-import-cost/build.mjs",
      "packages/native-fs-adapter/**"
    ]
  }
}
